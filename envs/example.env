# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and acquire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com
# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com
# Environment: local, staging, production
ENVIRONMENT=local
PROJECT_NAME="AgentOps Backend Kit"
STACK_NAME=agentops-backend-kit
# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=change-this-secret-key-at-least-32-bytes
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-this-password
# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
# Redis, ARQ
REDIS_URL=redis://localhost:6379/0
ARQ_QUEUE_NAME=agentops-backend-kit-tasks
ARQ_JOB_TIMEOUT_SECONDS=3600
ARQ_RESULT_TTL_SECONDS=3600
CODEX_JOB_MODEL=gpt-5.5
CODEX_JOB_REASONING_EFFORT=low
CODEX_JOB_WORKING_DIRECTORY=/tmp/agentops-backend-kit/codex_workspace
CODEX_JOB_SANDBOX_MODE=workspace-write
CODEX_JOB_APPROVAL_POLICY=never
CODEX_JOB_IDLE_TIMEOUT_SECONDS=60
CODEX_JOB_MAX_TURNS=10
JOB_EVENTS_STREAM_PREFIX=job-events
JOB_EVENTS_STREAM_MAXLEN=10000
CODEX_CLI_PATH=codex
CODEX_DEVICE_LOGIN_START_TIMEOUT_SECONDS=10
